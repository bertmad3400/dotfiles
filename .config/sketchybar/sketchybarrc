##### Spaces #####
# Layered workspaces: 5 "spaces" A..E, each with 10 workspaces (X0..X9).
# Bar shows: [A][B][C][D][E] | [X0][X1]...[X9]  where X is the active space.

sketchybar --add event aerospace_workspace_change

CURRENT_FOCUSED=$(aerospace list-workspaces --focused)
CURRENT_LETTER="${CURRENT_FOCUSED:0:1}"

# Space-letter indicators (one per "space"). Only the active one is drawn.
for L in A B C D E; do
    if [[ "$L" == "$CURRENT_LETTER" ]]; then
        LETTER_DRAW="on"
    else
        LETTER_DRAW="off"
    fi

    sketchybar --add item spaceletter.$L left \
        --set spaceletter.$L \
        drawing=$LETTER_DRAW \
        label="$L" \
        label.color=0xffffffff \
        label.font="Hack Nerd Font:Bold:16.0" \
        label.padding_left=6 \
        label.padding_right=6 \
        icon.padding_left=0 \
        icon.padding_right=0 \
        background.color=0x44ffffff \
        background.corner_radius=5 \
        background.height=20 \
        background.drawing=on \
        click_script="$PLUGIN_DIR/aerospace-goto.sh ${L}0"
done

# Visual divider between space letters and workspaces
sketchybar --add item space.divider left \
    --set space.divider \
        label="|" \
        label.color="0x55ffffff" \
        label.padding_left=0 \
        label.padding_right=4 \
        icon.padding_left=2 \
        icon.padding_right=2

# Per-workspace items (50 total). Only the current space's 10 are visible.
# Order within a space: 1,2,3,4,5,6,7,8,9,0 (0 last). Cache the workspace->display
# mapping once to avoid querying aerospace 50 times.
WS_LIST=$(aerospace list-workspaces --all --format "%{workspace},%{monitor-id}")

for WS_LETTER in A B C D E; do
    for WS_DIGIT in 1 2 3 4 5 6 7 8 9 0; do
        WORKSPACE="${WS_LETTER}${WS_DIGIT}"
        DISPLAY=$(printf '%s\n' "$WS_LIST" | grep "^${WORKSPACE}," | cut -d, -f2)

    if [[ "$WS_LETTER" == "$CURRENT_LETTER" ]]; then
        WS_DRAW="on"
    else
        WS_DRAW="off"
    fi

    sketchybar --add item space.$WORKSPACE left \
        --set space.$WORKSPACE \
        display=$DISPLAY \
        drawing=$WS_DRAW \
        label="$WS_DIGIT" \
        label.color="0xffffffff" \
        label.drawing=on \
        label.font="Hack Nerd Font:Bold:16.0" \
        label.padding_left=6 \
        label.padding_right=6 \
        icon="$WS_DIGIT" \
        icon.color="0xff000000" \
        icon.font="Hack Nerd Font:Bold:16.0" \
        icon.padding_left=6 \
        icon.padding_right=6 \
        icon.drawing=off \
        background.color=0xffffffff \
        background.corner_radius=5 \
        background.height=20 \
        background.drawing=off \
        click_script="$PLUGIN_DIR/aerospace-goto.sh $WORKSPACE"
    done
done

