PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/../colors.sh"

##### Bar Appearance #####

sketchybar --bar \
    position=top  \
    height=32  \
    y_offset=0  \
    padding_left=8  \
    padding_right=8 \
    color=0xff000000  \


##### Changing Defaults #####

default=(
  icon.font="Hack Nerd Font:Bold:17.0"
  label.font="Hack Nerd Font:Bold:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=3
  icon.padding_right=3
  label.padding_left=3
  label.padding_right=3
)
sketchybar --default "${default[@]}"


##### Spaces #####

sketchybar --add event aerospace_workspace_change

for WORKSPACE_AND_DISPLAY in $(aerospace list-workspaces --all --format "%{workspace},%{monitor-id}"); do

    WORKSPACE=$(echo $WORKSPACE_AND_DISPLAY | cut -d, -f1)
    DISPLAY=$(echo $WORKSPACE_AND_DISPLAY | cut -d, -f2)

    sketchybar --add item space.$WORKSPACE left \
        --set space.$WORKSPACE \
        display=$DISPLAY \
        label="$WORKSPACE" \
        label.color="0xffffffff" \
        label.drawing=on \
        label.font="Hack Nerd Font:Bold:16.0" \
        label.padding_left=6 \
        label.padding_right=6 \
        icon="$WORKSPACE" \
        icon.color="0xff000000" \
        icon.font="Hack Nerd Font:Bold:16.0" \
        icon.padding_left=6 \
        icon.padding_right=6 \
        icon.drawing=off \
        background.color=0xffffffff \
        background.corner_radius=5 \
        background.height=20 \
        background.drawing=off \
        click_script="aerospace workspace $WORKSPACE"
done

sketchybar --add item space.focus left --set space.focus script="$PLUGIN_DIR/aerospace-focus.sh" --subscribe space.focus aerospace_workspace_change
sketchybar --add item space.used left --set space.used script="$PLUGIN_DIR/aerospace-used.sh" update_freq=1

